PORT=3000
NODE_ENV=development

# MongoDB Atlas connection string.
# Get this from: Atlas Dashboard → Connect → Drivers → Node.js
MONGO_URI=

# Used to sign/verify JWTs issued at login (Week 5 auth).
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# SMTP settings for the "forgot password" reset-code email (Week 5).
# Leave these blank to develop without a real inbox — the reset code will
# just be printed in the backend terminal instead of emailed.
#
# Example for Gmail (use an App Password, not your normal password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASS=your-16-character-app-password
#   SMTP_FROM=youraddress@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
